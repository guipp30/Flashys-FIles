<!DOCTYPE html>
<html lang="en-GB">
  <!-- @import "head" -->
  <body>
    <!-- @import "header" -->

    <main>
      <!-- HERO + FORM ROW -->
      <section class="connect-hero">
        <div class="connect-left">
          <span class="star">★</span>
          <h1>Let's build this together.</h1>
          <p>
            Submit a tip, collaborate, or just say hey. We read every message
            and manually review all community submissions.
          </p>
          <ul class="social-list">
            <li>
              <a href="#"
                >Twitter / X
                <span
                  ><svg
                    width="14"
                    height="14"
                    viewBox="0 0 14 14"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <path
                      d="M6.07715 0.243836C6.40246 -0.0813869 6.92944 -0.0811701 7.25488 0.243836L13.0889 6.07684C13.1793 6.16734 13.244 6.2743 13.2842 6.38739C13.2888 6.40036 13.2939 6.4132 13.2979 6.42645C13.3093 6.46457 13.3164 6.50355 13.3223 6.54266C13.3283 6.58315 13.333 6.62452 13.333 6.66669C13.333 6.70858 13.3282 6.7495 13.3223 6.78973C13.3202 6.80371 13.3192 6.81785 13.3164 6.83173C13.3093 6.86725 13.2986 6.90151 13.2871 6.93524C13.2473 7.05223 13.1821 7.16229 13.0889 7.25555L7.25488 13.0886C6.92949 13.4138 6.40254 13.4138 6.07715 13.0886C5.75212 12.7631 5.75185 12.2352 6.07715 11.9099L10.4863 7.49969H0.833008C0.372826 7.49969 9.0104e-05 7.12685 0 6.66669C0 6.20645 0.372771 5.83368 0.833008 5.83368H10.4883L6.07715 1.42157C5.75212 1.0961 5.75185 0.569137 6.07715 0.243836Z"
                      fill="#000000"
                      fill-opacity="0.3"
                    />
                  </svg> </span
              ></a>
            </li>
            <li>
              <a href="#"
                >Instagram
                <span
                  ><svg
                    width="14"
                    height="14"
                    viewBox="0 0 14 14"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <path
                      d="M6.07715 0.243836C6.40246 -0.0813869 6.92944 -0.0811701 7.25488 0.243836L13.0889 6.07684C13.1793 6.16734 13.244 6.2743 13.2842 6.38739C13.2888 6.40036 13.2939 6.4132 13.2979 6.42645C13.3093 6.46457 13.3164 6.50355 13.3223 6.54266C13.3283 6.58315 13.333 6.62452 13.333 6.66669C13.333 6.70858 13.3282 6.7495 13.3223 6.78973C13.3202 6.80371 13.3192 6.81785 13.3164 6.83173C13.3093 6.86725 13.2986 6.90151 13.2871 6.93524C13.2473 7.05223 13.1821 7.16229 13.0889 7.25555L7.25488 13.0886C6.92949 13.4138 6.40254 13.4138 6.07715 13.0886C5.75212 12.7631 5.75185 12.2352 6.07715 11.9099L10.4863 7.49969H0.833008C0.372826 7.49969 9.0104e-05 7.12685 0 6.66669C0 6.20645 0.372771 5.83368 0.833008 5.83368H10.4883L6.07715 1.42157C5.75212 1.0961 5.75185 0.569137 6.07715 0.243836Z"
                      fill="#000000"
                      fill-opacity="0.3"
                    />
                  </svg> </span
              ></a>
            </li>
            <li>
              <a href="#"
                >Dribbble
                <span
                  ><svg
                    width="14"
                    height="14"
                    viewBox="0 0 14 14"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <path
                      d="M6.07715 0.243836C6.40246 -0.0813869 6.92944 -0.0811701 7.25488 0.243836L13.0889 6.07684C13.1793 6.16734 13.244 6.2743 13.2842 6.38739C13.2888 6.40036 13.2939 6.4132 13.2979 6.42645C13.3093 6.46457 13.3164 6.50355 13.3223 6.54266C13.3283 6.58315 13.333 6.62452 13.333 6.66669C13.333 6.70858 13.3282 6.7495 13.3223 6.78973C13.3202 6.80371 13.3192 6.81785 13.3164 6.83173C13.3093 6.86725 13.2986 6.90151 13.2871 6.93524C13.2473 7.05223 13.1821 7.16229 13.0889 7.25555L7.25488 13.0886C6.92949 13.4138 6.40254 13.4138 6.07715 13.0886C5.75212 12.7631 5.75185 12.2352 6.07715 11.9099L10.4863 7.49969H0.833008C0.372826 7.49969 9.0104e-05 7.12685 0 6.66669C0 6.20645 0.372771 5.83368 0.833008 5.83368H10.4883L6.07715 1.42157C5.75212 1.0961 5.75185 0.569137 6.07715 0.243836Z"
                      fill="#000000"
                      fill-opacity="0.3"
                    />
                  </svg> </span
              ></a>
            </li>
            <li>
              <a href="#"
                >Email
                <span
                  ><svg
                    width="14"
                    height="14"
                    viewBox="0 0 14 14"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <path
                      d="M6.07715 0.243836C6.40246 -0.0813869 6.92944 -0.0811701 7.25488 0.243836L13.0889 6.07684C13.1793 6.16734 13.244 6.2743 13.2842 6.38739C13.2888 6.40036 13.2939 6.4132 13.2979 6.42645C13.3093 6.46457 13.3164 6.50355 13.3223 6.54266C13.3283 6.58315 13.333 6.62452 13.333 6.66669C13.333 6.70858 13.3282 6.7495 13.3223 6.78973C13.3202 6.80371 13.3192 6.81785 13.3164 6.83173C13.3093 6.86725 13.2986 6.90151 13.2871 6.93524C13.2473 7.05223 13.1821 7.16229 13.0889 7.25555L7.25488 13.0886C6.92949 13.4138 6.40254 13.4138 6.07715 13.0886C5.75212 12.7631 5.75185 12.2352 6.07715 11.9099L10.4863 7.49969H0.833008C0.372826 7.49969 9.0104e-05 7.12685 0 6.66669C0 6.20645 0.372771 5.83368 0.833008 5.83368H10.4883L6.07715 1.42157C5.75212 1.0961 5.75185 0.569137 6.07715 0.243836Z"
                      fill="#000000"
                      fill-opacity="0.3"
                    />
                  </svg> </span
              ></a>
            </li>
          </ul>
        </div>
        <div class="connect-right">
          <div class="form-card">
            <h2>Suggest a Tip</h2>
            <p>Your hack could save thousands of hours.</p>
            <form>
              <label>Your Name</label>
              <input type="text" placeholder="Jane Doe" />

              <label>Email Address</label>
              <input type="email" placeholder="jane@studio.co" />

              <label>Category</label>
              <input type="text" />

              <label>Describe your tip</label>
              <textarea
                placeholder="I use a keyboard shortcut to instantly wrap layers in an auto-layout frame, then fit..."
              ></textarea>

              <button type="submit" class="btn btn-dark btn-full">
                Send It →
              </button>
              <p class="form-note">
                We review every submission. No spam, ever.
              </p>
            </form>
          </div>
        </div>
      </section>

      <!-- THE CURATORS -->
      <section class="curators">
        <h2>The Curators</h2>
        <div class="curators-grid">
          <div class="curator-card">
            <img
              src="../src/assets/img/Flashy.avif"
              alt="Flashy"
              class="avatar"
            />
            <h3>Flashy</h3>
            <p class="curator-role curator-red">FOUNDER &amp; EDITOR</p>
            <p>
              Obsessed with micro-interactions and typographic scales. Spends
              too much time in the right-hand panel.
            </p>
          </div>
          <div class="curator-card">
            <img
              src="../src/assets/img/Sarah.avif"
              alt="Sarah"
              class="avatar"
            />
            <h3>Sarah</h3>
            <p class="curator-role curator-yellow">DESIGN ENGINEER</p>
            <p>
              Translating static pixels into responsive, accessible code. The
              bridge between Figma and reality.
            </p>
          </div>
          <div class="curator-card">
            <img
              src="../src/assets/img/Marcus.avif"
              alt="Marcus"
              class="avatar"
            />
            <h3>Marcus</h3>
            <p class="curator-role curator-purple">SYSTEM ARCHITECT</p>
            <p>
              Builds the tokens, structures the libraries, and writes the
              documentation no one else wants to write.
            </p>
          </div>
        </div>
      </section>
    </main>

    <!-- @import "footer" -->
  </body>
</html>
