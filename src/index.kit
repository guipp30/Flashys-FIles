<!DOCTYPE html>
<html lang="en-GB">
  <!-- @import "head" -->
  <body>
    <!-- @import "header" -->

    <main>
      <!-- HERO -->
      <section class="hero">
        <div class="hero-content">
          <span class="tag">DESIGN RESOURCES</span>
          <h1>Stop searching.<br />Start shipping.</h1>
          <p>
            Battle-tested hacks, walkthroughs, and cheat sheets for designers
            who move fast.
          </p>
          <div class="hero-ctas">
            <a href="/sobre.html" class="btn btn-dark">Explore The Vault →</a>
            <a href="#this-weeks-best" class="btn btn-outline"
              >See What's Inside ↓</a
            >
          </div>
        </div>
        <div class="hero-visual">
          <!-- Floating cards — add images or CSS cards here -->
        </div>
      </section>

      <!-- THIS WEEK'S BEST -->
      <section class="this-weeks-best" id="this-weeks-best">
        <h2>This Week's Best</h2>
        <div class="cards-row">
          <article class="card">
            <span class="tag tag-yellow">
              <img src="../assets/img/Figma.svg" alt="Figma" />
              QUICK WIN
            </span>
            <h3>Auto Layout Shortcuts That Save 20 Min/Day</h3>
            <a href="/artigo.html">Read Post →</a>
          </article>
          <article class="card">
            <span class="tag tag-red">
              <img src="assets/img/Compass.svg" alt="Compass" />
              DEEP DIVE
            </span>
            <h3>Responsive Card Components in 8 Steps</h3>
            <a href="/artigo.html">Read Post →</a>
          </article>
          <article class="card">
            <svg
              width="40"
              height="40"
              viewBox="0 0 40 40"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M16 24H24V20H16V24ZM16 18H32V14H16V18ZM16 12H32V8H16V12ZM12 32C10.9 32 9.95833 31.6083 9.175 30.825C8.39167 30.0417 8 29.1 8 28V4C8 2.9 8.39167 1.95833 9.175 1.175C9.95833 0.391667 10.9 0 12 0H36C37.1 0 38.0417 0.391667 38.825 1.175C39.6083 1.95833 40 2.9 40 4V28C40 29.1 39.6083 30.0417 38.825 30.825C38.0417 31.6083 37.1 32 36 32H12ZM12 28H36V4H12V28ZM4 40C2.9 40 1.95833 39.6083 1.175 38.825C0.391667 38.0417 0 37.1 0 36V8H4V36H32V40H4ZM12 4V28V4Z"
                fill="white"
              />
            </svg>
            <span class="tag tag-purple"> CHEAT SHEET </span>
            <h3>WCAG Accessibility Checklist for UI Designers</h3>
            <a href="/artigo.html">Read Post →</a>
          </article>
          <article class="card">
            <span class="tag tag-yellow">
              <img src="assets/img/Star.svg" alt="Star" />
              QUICK WIN
            </span>
            <h3>Perfecting Button States and Micro-interactions</h3>
            <a href="/artigo.html">Read Post →</a>
          </article>
        </div>
      </section>

      <!-- EXPLORE THE LIBRARY -->
      <section class="explore-library">
        <h2>Explore the Library</h2>
        <div class="category-grid">
          <div class="category-card category-yellow">
            <span class="icon">⚡</span>
            <h3>Quick Wins</h3>
            <p>5-minute fixes to elevate your UI instantly.</p>
            <a href="#" class="btn btn-dark">Browse Category</a>
          </div>
          <div class="category-card category-dark">
            <span class="icon">▦</span>
            <h3>Deep Dives</h3>
            <p>Comprehensive studies on UX patterns and psychology.</p>
            <a href="#" class="btn btn-outline-light">Browse Category</a>
          </div>
          <div class="category-card category-purple">
            <span class="icon">⊞</span>
            <h3>Cheat Sheets</h3>
            <p>Downloadable PDF guides for quick reference.</p>
            <a href="#" class="btn btn-dark">Browse Category</a>
          </div>
        </div>
      </section>
    </main>

    <!-- @import "footer" -->
  </body>
</html>
