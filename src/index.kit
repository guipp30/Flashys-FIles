<!DOCTYPE html>
<html lang="en-GB">
  <!-- @import "head" -->
  <body>
    <!-- @import "header" -->

    <main>
      <!-- HERO -->
      <section class="hero">
        <div class="hero-content">
          <span class="tag">DESIGN RESOURCES</span>
          <h1>Stop searching.<br />Start shipping.</h1>
          <p>
            Battle-tested hacks, walkthroughs, and cheat sheets for designers
            who move fast.
          </p>
          <div class="hero-ctas">
            <a href="/sobre.html" class="btn btn-dark secondary">Explore The Vault →</a>
            <a href="#this-weeks-best" class="btn btn-outline"
              >See What's Inside ↓</a
            >
          </div>
        </div>
        <div class="hero-visual">
          <picture class="hero-image"
            ><source
              srcset="../assets/img/floatingCards-hero.svg"
              type="image/avif"
            />
            <img
              src="../src/assets/img/floatingCards-hero.svg"
              alt="Illustration of a designer working on a laptop, surrounded by design elements and resources."
            />
          </picture>
        </div>
      </section>

      <!-- THIS WEEK'S BEST -->
      <section class="this-weeks-best" id="this-weeks-best">
        <h2>This Week's Best</h2>
        <div class="cards-row">
          <!-- Card 1 — Quick Win -->
          <article class="card">
            <div class="card-stripe card-stripe--lime"></div>
            <div class="card-body">
