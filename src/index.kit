      </section>

      <!-- EXPLORE THE LIBRARY -->
      <section class="explore-library">
        <h2>Explore the Library</h2>
        <div class="category-grid">
          <div class="category-card category-yellow">
            <svg
              width="32"
              height="40"
              viewBox="0 0 32 40"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M13.1 32.4L23.45 20H15.45L16.9 8.65L7.65 22H14.6L13.1 32.4ZM8 40L10 26H0L18 0H22L20 16H32L12 40H8Z"
                fill="black"
              />
            </svg>
            <h3>Quick Wins</h3>
            <p>5-minute fixes to elevate your UI instantly.</p>
            <a href="#" class="btn btn-dark ">Browse Category</a>
          </div>
          <div class="category-card category-dark">
            <svg
              width="40"
              height="40"
              viewBox="0 0 40 40"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
