                >Handling Dark Mode</a
              >
            </nav>
          </div>

          <!-- Pro Tip Callout -->
          <div class="sidebar-tip">
            <div class="sidebar-tip-label">
              <span>PRO TIP</span>
            </div>
            <p>
              Never use the 1px grid inside components. Reserve it strictly for
              the macro layout to avoid a cluttered "spreadsheet" look.
            </p>
          </div>

