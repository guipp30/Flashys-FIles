            <a
              href="../articles/3-clickFigmaComponent.html"
              class="related-card"
            >
              <p class="related-card-title">The 3-Click Figma Component Swap</p>
              <span class="related-card-link">Read More →</span>
            </a>
          </div>
        </aside>
      </div>
      <!-- end .article-layout -->
    </main>

