<!DOCTYPE html>
<html lang="en-GB">
  <!-- @import "head" -->
  <body>
    <!-- @import "header" -->

    <main class="articles-page">
      <!-- DARK HERO BANNER -->
      <section class="articles-hero">
        <span class="tag">47 RESOURCES</span>
        <h1>Articles</h1>
        <p>Every hack. Every walkthrough. Every shortcut. All in one place.</p>
      </section>

      <!-- SEARCH + FILTERS -->
      <section class="articles-filter">
        <div class="search-bar">
          <input
            type="text"
            id="articles-search"
            placeholder="Search tips..."
          />
        </div>
        <div class="filter-tabs">
          <button class="active" data-filter="all">All</button>
          <button data-filter="quick-win">Quick Win</button>
          <button data-filter="deep-dive">Deep Dives</button>
          <button data-filter="cheat-sheet">Cheat Sheets</button>
        </div>
      </section>

      <!-- ARTICLE CARDS GRID -->
      <section class="articles-grid" id="articles-grid">
        <article class="article-card" data-category="quick-win">
          <span class="tag tag-yellow">QUICK WIN</span>
          <h3>The 3-Click Figma Component Swap</h3>
          <p>
            Stop manually detaching instances. This keyboard shortcut swaps
            components globally without breaking auto-layout.
          </p>
          <div class="card-meta">
            <span>2 min read</span>
            <a href="../articles/3-clickFigmaComponent.html">Read More →</a>
          </div>
        </article>
        <article class="article-card" data-category="deep-dive">
          <span class="tag tag-red">DEEP DIVE</span>
          <h3>Building a Design Token System from Scratch</h3>
          <p>
            A comprehensive guide to naming, organizing, and distributing design
            tokens across Figma and codebase.
          </p>
          <div class="card-meta">
            <span>12 min read</span>
            <a href="../articles/building-design-system.html">Read More →</a>
          </div>
        </article>
        <article class="article-card" data-category="cheat-sheet">
          <span class="tag tag-purple">CHEAT SHEET</span>
          <h3>The 12 Font Pairings That Always Work</h3>
          <p>
            A downloadable reference of editorial typography pairings for modern
            SaaS and e-commerce websites.
          </p>
          <div class="card-meta">
            <span>5 min read</span>
            <a href="../articles/12-fontPairings.html">Read More →</a>
          </div>
        </article>
      </section>

      <div class="load-more" style="display: none">
        <a href="#" class="btn btn-dark">Load More Tips →</a>
      </div>
    </main>

    <!-- @import "footer" -->
  </body>
</html>
